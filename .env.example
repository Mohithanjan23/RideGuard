# RideGuard — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ── Development mode ─────────────────────────────────────────────────────────
# Set to "false" to use real platform adapters instead of mock data.
# Default: true (mock mode — no platform credentials needed)
REACT_APP_USE_MOCK=true

# ── Uber ─────────────────────────────────────────────────────────────────────
# Register at: https://developer.uber.com
# Required scopes: profile, ride_widgets, request (Rider API)
REACT_APP_UBER_CLIENT_ID=
REACT_APP_UBER_CLIENT_SECRET=
REACT_APP_UBER_REDIRECT_URI=http://localhost:3000/auth/uber/callback

# ── Lyft ─────────────────────────────────────────────────────────────────────
# Register at: https://www.lyft.com/developers
# Required scopes: rides.read, profile
REACT_APP_LYFT_CLIENT_ID=
REACT_APP_LYFT_CLIENT_SECRET=
REACT_APP_LYFT_REDIRECT_URI=http://localhost:3000/auth/lyft/callback

# ── Bolt ─────────────────────────────────────────────────────────────────────
# Partner API access required: https://developers.bolt.eu
REACT_APP_BOLT_API_KEY=
REACT_APP_BOLT_CLIENT_ID=

# ── Via ───────────────────────────────────────────────────────────────────────
# Developer access by request: https://developer.ridewithvia.com
REACT_APP_VIA_API_KEY=

# ── Feature flags ────────────────────────────────────────────────────────────
# Conflict detection window in minutes (default: 90)
REACT_APP_CHECK_WINDOW_MINUTES=90

# Enable verbose audit logging to the browser console (default: false)
REACT_APP_DEBUG_LOGGING=false
